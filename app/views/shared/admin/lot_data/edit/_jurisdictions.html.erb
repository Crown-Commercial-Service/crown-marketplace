<% @jurisdictions.each do |group, jurisdictions| %>
  <%= govuk_checkboxes(
    :'supplier_framework_lot[jurisdiction_ids]',
    jurisdictions.sort_by(&:name).map do |jurisdiction|
      {
        value: jurisdiction.id,
        checked: @supplier_framework_lot_jurisdiction_ids.include?(jurisdiction.id),
        label: {
          text: "#{jurisdiction.name} (#{jurisdiction.code})"
        },
        attributes: {
          id: "jurisdiction_#{jurisdiction.id.gsub('.', '-')}"
        }
      }
    end,
    fieldset: {
      legend: {
        text: group.nil? ? t('.question') : t('.question_group', group: group),
        classes: 'govuk-fieldset__legend--m',
      }
    },
    error_message: @model.errors[:base].first
  ) %>
<% end %>